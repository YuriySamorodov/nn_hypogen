# ============================================================
# data2md v2.0.0 — конфигурация
# Скопируйте этот файл в .env и заполните нужные значения.
# Всё, что задано здесь, можно переопределить соответствующим CLI-флагом
# (флаг всегда имеет приоритет над .env).
# ============================================================

# Пути по умолчанию
INPUT_DIR="./данные"
OUTPUT_DIR="./repomix_input"

# Корпусный строитель (repomix или yek)
CORPUS_BUILDER="repomix"

# --- Vision API (для изображений) ---
VISION_MODEL="qwen2.5-vl:7b"          # модель (для ollama — тег модели)
VISION_PROVIDER="ollama"              # ollama, deepseek, vk, yandex
VISION_OLLAMA_HOST="http://localhost:11434"
VISION_DEEPSEEK_API_KEY=""            # ключ для Deepseek Vision API
VISION_VK_API_KEY=""                  # ключ для VK Vision API
VISION_YANDEX_CLOUD_API_KEY=""        # ключ для Yandex Cloud Vision API

# Кеш описаний изображений (SHA-256 файла -> текст описания).
# Экономит повторные платные/медленные вызовы Vision API при повторных запусках.
# Пусто = <OUTPUT_DIR>/.data2md_vision_cache.json (по умолчанию).
VISION_CACHE_FILE=""

# --- Параметры обработки ---
MAX_TABLE_ROWS=50                     # макс. строк из Excel/CSV в Markdown
PDF_PAGE_LIMIT=0                      # 0 = все страницы
IMAGE_ENABLED=true                    # обрабатывать изображения
TEXT_ENABLED=true                     # обрабатывать текст/PDF/DOCX
TABLE_ENABLED=true                    # обрабатывать таблицы Excel/CSV

# Параллельная обработка файлов
WORKERS=4                             # число потоков (Vision API — узкое место, обычно 4-8)

# Пропускать файлы больше указанного размера, чтобы не зависать на гигантских PDF/сканах
MAX_FILE_SIZE_MB=200

# --- Параметры вывода ---
INCLUDE_STATS=true                    # добавлять статистику для таблиц (min/max/mean/...)
INCLUDE_KEY_METRICS=true              # извлекать ключевые метрики (Ni, Cu, потери...)
VERBOSE=false                         # подробный вывод (DEBUG-уровень логов)

# Фильтрация (по умолчанию пусто — обрабатывать все поддерживаемые форматы)
EXTENSIONS_INCLUDE=""                 # например: ".png,.xlsx"
EXTENSIONS_EXCLUDE=".log,.tmp"        # исключить расширения

# ============================================================
# Параметры ниже управляются только через CLI-флаги и здесь не задаются:
#   --dry-run        — предпросмотр без записи файлов
#   --no-cache        — отключить кеш описаний изображений
#   --summary-json    — сохранить JSON-отчёт о прогоне
# ============================================================
