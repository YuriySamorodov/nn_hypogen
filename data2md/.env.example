# ============================================================
# data2md — конфигурация
# ============================================================

# Пути по умолчанию
INPUT_DIR="./данные"
OUTPUT_DIR="./repomix_input"

# Корпусный строитель (repomix или yek)
CORPUS_BUILDER="repomix"

# Модели (используются если установлены)
VISION_MODEL="qwen2.5-vl:7b"         # для изображений (через ollama)
VISION_OLLAMA_HOST="http://localhost:11434"
VISION_PROVIDER="ollama"             # провайдер Vision API: ollama, deepseek, vk, yandex
VISION_DEEPSEEK_API_KEY=""           # ключ для Deepseek Vision API
VISION_VK_API_KEY=""                 # ключ для VK Vision API
VISION_YANDEX_CLOUD_API_KEY=""       # ключ для Yandex Cloud Vision API

# Параметры обработки
MAX_TABLE_ROWS=50                     # макс. строк из Excel в Markdown
PDF_PAGE_LIMIT=0                      # 0 = все страницы
IMAGE_ENABLED=true                    # обрабатывать изображения
TEXT_ENABLED=true                     # обрабатывать текст/PDF/DOCX
TABLE_ENABLED=true                    # обрабатывать таблицы Excel/CSV

# Параметры вывода
INCLUDE_STATS=true                    # добавлять статистику для таблиц
INCLUDE_KEY_METRICS=true             # извлекать ключевые метрики (Ni, Cu...)
VERBOSE=false                        # подробный вывод

# Фильтрация (по умолчанию пусто — обрабатывать все)
EXTENSIONS_INCLUDE=""                 # например: ".png,.xlsx"
EXTENSIONS_EXCLUDE=".log,.tmp"       # исключить расширения